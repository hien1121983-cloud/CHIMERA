# Fallback (chỉ outline)
GROQ_API_KEY=

# Image
HF_TOKEN=

# ===== ElevenLabs — 6 key xoay vòng (Round-Robin) =====
# Khi key chạm 401/429 (hết quota) -> tự sang key kế.
# Cạn cả 6 -> fallback edge-tts (free, không crash).
ELEVENLABS_KEY1=
ELEVENLABS_KEY2=
ELEVENLABS_KEY3=
ELEVENLABS_KEY4=
ELEVENLABS_KEY5=
ELEVENLABS_KEY6=
# (tuỳ chọn) tương thích ngược: nếu chỉ có 1 key
ELEVENLABS_API_KEY=

EDGE_VOICE=vi-VN-NamMinhNeural

# ===== 3 cụm MongoDB =====
MONGODB_URL_NO1=
MONGODB_URL_NO2=
MONGODB_URL_NO3=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Phải set để webhook trigger được workflow assemble_video.yml
