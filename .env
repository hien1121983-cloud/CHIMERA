# === MONGODB ATLAS (3 cum) ===
MONGODB_URI_PERMANENT=mongodb+srv://...
MONGODB_URI_PURGATORY=mongodb+srv://...
MONGODB_URI_CANON=mongodb+srv://...

# === GOOGLE CLOUD STORAGE ===
GCS_BUCKET_NAME=chimera-backup-prod
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# === LOCAL ===
LOCAL_CACHE_PATH=./cache/local_cache.sqlite
ARCHETYPE_CACHE_PATH=./cache/archetypes_cache.json
LOG_LEVEL=INFO

# === CONFIGURATION (Va I-02, I-03, I-06) ===
LOCATION_COOLDOWN_EPISODES=3
SIMILARITY_THRESHOLD=0.70
AUDITOR_MAX_RETRY=3
RESOURCE_LOCK_MAX_CONCURRENT=2
RESOURCE_LOCK_MAX_RAM_PERCENT=75.0
FFMPEG_THREADS=2
FFMPEG_CRF=28
FFMPEG_PRESET=veryfast
